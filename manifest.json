{
  "manifest_version": 3,
  "name": "skills-eye",
  "version": "1.0.0",
  "description": "为 skills.sh 添加亮色/暗色/跟随系统主题切换，护眼必备",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://skills.sh/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://skills.sh/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "skills-eye",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
